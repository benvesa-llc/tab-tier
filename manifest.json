{
  "manifest_version": 3,
  "name": "Tab Lifecycle Manager",
  "version": "0.2.9",
  "description": "Tier-based automatic tab lifecycle management for Edge",
  "default_locale": "en",
  "permissions": ["tabs", "tabGroups", "alarms", "storage"],
  "background": {
    "service_worker": "background.js"
  },
  "icons": {
    "16": "icons/icon-16.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "Tab Lifecycle Manager",
    "default_icon": {
      "16": "icons/icon-16.png",
      "48": "icons/icon-48.png"
    }
  },
  "web_accessible_resources": [
    {
      "resources": ["debug.html", "debug.js"],
      "matches": ["<all_urls>"]
    }
  ]
}
